# ==========================
# Dockerfile Simplificado
# ==========================
FROM eclipse-temurin:21-jre

WORKDIR /app

# Copia o JAR já construído localmente
COPY build/libs/*.jar app.jar

# Expõe porta padrão do Spring Boot
EXPOSE 8080

# Comando de inicialização
ENTRYPOINT ["java", "-jar", "app.jar"]