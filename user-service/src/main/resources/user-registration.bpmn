<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.45.0">
  <bpmn:process id="UserRegistrationProcess" name="User Registration" isExecutable="true" camunda:historyTimeToLive="30">
    <bpmn:serviceTask id="Task_ValidateData" name="Validar Dados" camunda:delegateExpression="${validateUserDataDelegate}">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_CheckExists" name="Verificar Usuário Existente" camunda:delegateExpression="${checkUserExistsDelegate}">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_UserExists" name="Usuário existe?" default="Flow_Create">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_Create</bpmn:outgoing>
      <bpmn:outgoing>Flow_Error</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_CreateUser" name="Criar Usuário" camunda:delegateExpression="${createUserDelegate}">
      <bpmn:incoming>Flow_Create</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_SendKafka" name="Enviar Evento Kafka" camunda:delegateExpression="${sendKafkaEventDelegate}">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_GenerateToken" name="Gerar Token JWT" camunda:delegateExpression="${generateTokenDelegate}">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_Success" name="Registro Completo">
      <bpmn:incoming>Flow_6</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="EndEvent_Error" name="Erro no Registro">
      <bpmn:incoming>Flow_Error</bpmn:incoming>
      <bpmn:errorEventDefinition errorRef="Error_UserExists" />
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent" targetRef="Task_ValidateData" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_ValidateData" targetRef="Task_CheckExists" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_CheckExists" targetRef="Gateway_UserExists" />
    <bpmn:sequenceFlow id="Flow_Create" sourceRef="Gateway_UserExists" targetRef="Task_CreateUser" />
    <bpmn:sequenceFlow id="Flow_Error" sourceRef="Gateway_UserExists" targetRef="EndEvent_Error">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${userExists == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Task_CreateUser" targetRef="Task_SendKafka" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Task_SendKafka" targetRef="Task_GenerateToken" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="Task_GenerateToken" targetRef="EndEvent_Success" />
    <bpmn:startEvent id="StartEvent" name="Início do Registro">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DataOutputAssociation_1r0umsp">
        <bpmn:targetRef>DataObjectReference_12dfjue</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
      <bpmn:messageEventDefinition id="MessageEventDefinition_1jgokun" messageRef="Message_3ebhg9f" />
    </bpmn:startEvent>
    <bpmn:dataObjectReference id="DataObjectReference_12dfjue" name="AuthRegisterDTO" dataObjectRef="DataObject_1g1wjxb" />
    <bpmn:dataObject id="DataObject_1g1wjxb" />
  </bpmn:process>
  <bpmn:error id="Error_UserExists" name="UserAlreadyExists" errorCode="USER_EXISTS" />
  <bpmn:message id="Message_3ebhg9f" name="Register User" />
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="UserRegistrationProcess">
      <bpmndi:BPMNShape id="Task_ValidateData_di" bpmnElement="Task_ValidateData">
        <dc:Bounds x="240" y="240" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_CheckExists_di" bpmnElement="Task_CheckExists">
        <dc:Bounds x="390" y="240" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_UserExists_di" bpmnElement="Gateway_UserExists" isMarkerVisible="true">
        <dc:Bounds x="545" y="255" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="532" y="225" width="76" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_CreateUser_di" bpmnElement="Task_CreateUser">
        <dc:Bounds x="650" y="240" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SendKafka_di" bpmnElement="Task_SendKafka">
        <dc:Bounds x="800" y="240" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_GenerateToken_di" bpmnElement="Task_GenerateToken">
        <dc:Bounds x="950" y="240" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Success_di" bpmnElement="EndEvent_Success">
        <dc:Bounds x="1102" y="262" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1096" y="305" width="48" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Error_di" bpmnElement="EndEvent_Error">
        <dc:Bounds x="552" y="392" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="530" y="435" width="81" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_0m9qcwh_di" bpmnElement="StartEvent">
        <dc:Bounds x="152" y="262" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="127" y="305" width="86" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="DataObjectReference_12dfjue_di" bpmnElement="DataObjectReference_12dfjue">
        <dc:Bounds x="152" y="85" width="36" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="126" y="61" width="87" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="188" y="280" />
        <di:waypoint x="240" y="280" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="340" y="280" />
        <di:waypoint x="390" y="280" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="490" y="280" />
        <di:waypoint x="545" y="280" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Create_di" bpmnElement="Flow_Create">
        <di:waypoint x="595" y="280" />
        <di:waypoint x="650" y="280" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Error_di" bpmnElement="Flow_Error">
        <di:waypoint x="570" y="305" />
        <di:waypoint x="570" y="392" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_4_di" bpmnElement="Flow_4">
        <di:waypoint x="750" y="280" />
        <di:waypoint x="800" y="280" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_5_di" bpmnElement="Flow_5">
        <di:waypoint x="900" y="280" />
        <di:waypoint x="950" y="280" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_6_di" bpmnElement="Flow_6">
        <di:waypoint x="1050" y="280" />
        <di:waypoint x="1102" y="280" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="DataOutputAssociation_1r0umsp_di" bpmnElement="DataOutputAssociation_1r0umsp">
        <di:waypoint x="170" y="262" />
        <di:waypoint x="168" y="135" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
